{
  "name": "craftify-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Craftify Templates Marketplace - Monorepo with Next.js website and React admin dashboard",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:website\" \"npm run dev:dashboard\" \"npm run dev:api\"",
    "dev:website": "npm run dev --workspace=apps/website",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspaces",
    "build:website": "npm run build --workspace=apps/website",
    "build:dashboard": "npm run build --workspace=apps/dashboard",
    "lint": "npm run lint --workspaces",
    "clean": "npm run clean --workspaces && rm -rf node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
