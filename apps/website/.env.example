# Base URL of the Craftify API (no trailing slash). Must match backend listen port (backend PORT / default 3000).
# Copy to `.env.local` if your API is not on http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Never set in production: allows completing checkout without Stripe (creates unpaid orders). Default is Stripe-only.
# NEXT_PUBLIC_ALLOW_CHECKOUT_WITHOUT_STRIPE=true
